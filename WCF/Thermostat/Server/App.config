<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
	<system.serviceModel>
		<services>
			<service name="Server.ThermostatService">
				<endpoint contract="Server.IThermostatService"
						  address="http://localhost:8080/WCFService"
						  binding="wsDualHttpBinding"></endpoint>
			</service>
		</services>
	</system.serviceModel>
</configuration>