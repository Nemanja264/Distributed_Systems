<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
	<system.serviceModel>
		<client>
			<endpoint name="vSer"
					  address="http://localhost:8080/WCFService"
					  binding="wsDualHttpBinding"
					  contract="Server.IVoteService"></endpoint>
		</client>
	</system.serviceModel>
</configuration>